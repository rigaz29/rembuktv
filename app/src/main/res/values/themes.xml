<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- App is fully Jetpack Compose; this XML theme only styles the window/splash
         frame before Compose draws. Based on the framework Material theme so we do
         not need the Material Components (View) dependency. -->
    <style name="Theme.LiveTV" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>
